# ============================================================
# .gitignore — Root Project: php-laravel-sederhana
# ============================================================

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── IDE & Editor ─────────────────────────────────────────────
.idea/
.vscode/
.cursor/
.nova/
.zed/
*.swp
*.swo
*~

# ── Laravel App (app/) ───────────────────────────────────────
app/.env
app/.env.backup
app/.env.production
app/vendor/
app/node_modules/
app/storage/*.key
app/storage/pail/
app/public/hot
app/public/build/
app/public/storage
app/.phpunit.result.cache
app/.phpunit.cache/
app/bootstrap/cache/*.php
app/auth.json
app/*.log

# ── Docker ───────────────────────────────────────────────────
.dockerignore

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── Misc ─────────────────────────────────────────────────────
*.zip
*.tar.gz
